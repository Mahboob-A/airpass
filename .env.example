# .env.example — Copy to .env and fill in real values before deploying
# NEVER commit .env — it contains secrets

# ── Application ──────────────────────────────────────────────
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Security ─────────────────────────────────────────────────
# Generate a random key: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME
BCRYPT_ROUNDS=12

# ── TURN Server (required for production) ────────────────────
# Without TURN, ~15-20% of users on symmetric NAT cannot connect.
# Use Coturn (self-hosted) or Metered.ca (managed service).
TURN_URL=turn:your-domain.com:3478
TURN_USERNAME=
TURN_CREDENTIAL=

# ── Room Settings ────────────────────────────────────────────
ROOM_EXPIRY_MINUTES=30
MAX_ROOMS=5000
